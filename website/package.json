{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "zip:homework": "node scripts/zip-homework.mjs",
    "zip:homework:watch": "node scripts/zip-homework.mjs --watch",
    "docusaurus": "docusaurus",
    "start": "concurrently -n ZIP,DOCS \"npm:zip:homework:watch\" \"docusaurus start\"",
    "build": "npm run zip:homework && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "npm run zip:homework && docusaurus deploy",
    "publish:site": "npm run zip:homework && docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
