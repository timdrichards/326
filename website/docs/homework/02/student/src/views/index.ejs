<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HW2 Starter</title>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <style>
      body { font-family: sans-serif; max-width: 900px; margin: 2rem auto; }
      .row { display: flex; gap: 0.5rem; }
      .entry { border: 1px solid #ddd; padding: 0.75rem; margin-bottom: 0.5rem; }
      .muted { color: #666; }
      .done { text-decoration: line-through; opacity: 0.7; }
      .error { color: #b00020; margin: 0.5rem 0; }
    </style>
  </head>
  <body>
    <h1>Homework 2 Starter: Entries</h1>

    <p class="muted">Complete TODO(HW2) items and extend this scaffold to satisfy assignment requirements.</p>

    <div class="row" style="margin-bottom: 1rem;">
      <input
        type="text"
        name="q"
        placeholder="Search entries..."
        hx-get="/entries/search"
        hx-trigger="keyup changed delay:300ms"
        hx-target="#entries"
        hx-swap="innerHTML"
      />
    </div>

    <form
      hx-post="/entries"
      hx-target="#entries"
      hx-swap="innerHTML"
      class="row"
      style="margin-bottom: 0.75rem;"
    >
      <input name="title" placeholder="Title" />
      <input name="body" placeholder="Body" />
      <button type="submit">Create</button>
    </form>

    <div id="errors"></div>

    <div id="entries">
      <%- include("partials/entryList", { entries }) %>
    </div>
  </body>
</html>
