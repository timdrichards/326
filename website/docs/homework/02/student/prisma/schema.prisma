generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Entry {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // TODO(HW2): Add at least one additional field or invariant-related constraint.
}
