generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Entry {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  tag         String   @default("general")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
