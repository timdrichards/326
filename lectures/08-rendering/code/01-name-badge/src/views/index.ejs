<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>HTMX Name Badge</title>
    <script src="https://unpkg.com/htmx.org@2.0.8"></script>
    <style>
      body { font-family: system-ui, sans-serif; padding: 2rem; }
      .layout { max-width: 640px; }
      .box { border: 1px solid #ddd; border-radius: 12px; padding: 1rem; }
      form { display: grid; gap: .75rem; }
      label { display: grid; gap: .25rem; font-weight: 600; }
      input { padding: .5rem .65rem; border: 1px solid #bbb; border-radius: 8px; font: inherit; }
      button { width: fit-content; padding: .45rem .8rem; }
      #result { margin-top: 1rem; min-height: 6.5rem; }
      .hint { color: #666; font-size: .9rem; margin-top: .75rem; }
      .code { background: #f6f6f6; border-radius: 4px; padding: .05rem .3rem; }
    </style>
  </head>
  <body>
    <div class="layout">
      <h1>Name Badge (HTMX Form POST)</h1>

      <div class="box">
        <form
          action="/badge"
          method="post"
          hx-post="/badge"
          hx-target="#result"
        >
          <label>
            Name
            <input name="name" placeholder="Ada Lovelace" required />
          </label>

          <label>
            Title
            <input name="title" placeholder="Rendering Detective" />
          </label>

          <button type="submit">Make badge</button>
        </form>

        <div id="result">
          <% if (typeof badge !== 'undefined') { %>
            <%- include("partials/badge-result", { badge }) %>
          <% } else { %>
            <div class="hint">Submit the form to render a server-generated badge here.</div>
          <% } %>
        </div>

        <div class="hint">
          The form is normal HTML (<span class="code">action</span> + <span class="code">method</span>).
          HTMX intercepts it with <span class="code">hx-post</span> and swaps only <span class="code">#result</span> via <span class="code">hx-target</span>.
        </div>
      </div>
    </div>
  </body>
</html>
